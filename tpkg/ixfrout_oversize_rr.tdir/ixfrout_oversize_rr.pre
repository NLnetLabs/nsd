# #-- ixfrout_oversize_rr.pre--#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test
. ../common.sh

# start NSD
get_random_port 2
TPKG_PORT=$RND_PORT
TPKG_CTRL_PORT=`expr $RND_PORT + 1`

PRE="../.."
TPKG_NSD="$PRE/nsd"

sed -e "s/TPKG_CTRL_PORT/"$TPKG_CTRL_PORT"/" < ixfrout_oversize_rr.conf > edit.conf

# share the vars
echo "export TPKG_PORT=$TPKG_PORT" >> .tpkg.var.test
echo "export TPKG_CTRL_PORT=$TPKG_CTRL_PORT" >> .tpkg.var.test

# put an oversized RR in the zone version 2.
# That does not fit in a 65535 message.
echo "txt IN TXT (" >> ixfrout_oversize_rr.zone2
for((i=0; i<255; i++)); do
	# 255 long string, with length is 256 bytes.
	echo '"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"' >> ixfrout_oversize_rr.zone2
done
# and a 254 long string, with length is 255 bytes.
# for 255*256 + 255 = 65535 bytes rdata for the TXT record
echo '"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"' >> ixfrout_oversize_rr.zone2
echo ")" >> ixfrout_oversize_rr.zone2

$TPKG_NSD -c edit.conf -u "" -p $TPKG_PORT
wait_nsd_up nsd.log
