# #-- xfrd_short_soa_response.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh

ldns-notify 127.0.0.1 -p $TPKG_PORT -z victim -s 2
sleep 1
if [ -f nsd-crashed ]; then
	echo "NSD crashed on receiving a short response to a SOA query from xfrd"
	exit 1
fi
