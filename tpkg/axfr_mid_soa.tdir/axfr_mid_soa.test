# #-- axfr_mid_soa.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh
PRE="../.."

# test with zone transfer
wait_logfile nsd.log "xfrd: zone example.com. bad transfer" 3
echo ""
echo "> dig example.com"
dig @127.0.0.1 -p $TPKG_PORT example.com SOA > cur
cat cur
if grep "SERVFAIL" cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo ""
echo "> dig example.com AXFR"
dig @127.0.0.1 -p $TPKG_PORT example.com AXFR > cur
cat cur
if grep "failed" cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

# test that server is up
echo ""
echo "> dig example.com"
dig @127.0.0.1 -p $TPKG_PORT example.com SOA > cur
cat cur
if grep "SERVFAIL" cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo "OK"
exit 0
