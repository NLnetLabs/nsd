# #-- tsig_del_axfr.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh
PRE="../.."

wait_logfile nsd.log "request incremental zone transfer (IXFR) for example.com." 10
$PRE/nsd-control -c edit.conf assoc_tsig example.com. k2
$PRE/nsd-control -c edit.conf del_tsig k1
# interrupts the zone transfer with the control command.
if test $? -ne 0; then
	echo "control command not OK"
	exit 1
fi

sleep 5

echo ""
echo "> dig example.com"
dig @127.0.0.1 -p $TPKG_PORT example.com SOA > cur
cat cur
if grep "root.example.com." cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo "OK"
exit 0
