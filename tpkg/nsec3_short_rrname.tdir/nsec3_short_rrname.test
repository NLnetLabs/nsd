# #-- nsec3_short_rrname.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test
. ../common.sh

PRE="../.."
TPKG_NSD="$PRE/nsd"

# Bring up the server.
$TPKG_NSD -c nsec3_short_rrname.conf -u "" -p $TPKG_PORT -P $TPKG_NSD_PID
wait_nsd_up nsd.log

# The server should be up.
dig @127.0.0.1 -p $TPKG_PORT SOA example.net > cur
cat cur
if grep "leela.example.net" cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo "OK"
exit 0
