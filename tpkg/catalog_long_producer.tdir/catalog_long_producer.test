# #-- catalog_long_producer.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh
PRE="../.."

# check that server is up
echo "nsd-control status"
$PRE/nsd-control -c edit.conf status
if test $? -ne 0; then
	echo "not OK"
	exit 1
fi

# add member zone to catalog producer
$PRE/nsd-control -c edit.conf addzone member.example. producer-pattern 

sleep 3

# test that server is up
echo ""
echo "> dig version.server CH TXT"
dig @127.0.0.1 -p $TPKG_PORT version.server CH TXT > cur
cat cur
if grep "NSD" cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo "OK"
exit 0
