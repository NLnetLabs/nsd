# #-- notify_ahead_perpetual.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh
PRE="../.."

# wait for serial 101 to be loaded.
# then, send a notify with serial 150
# the upstream primary continues to serve 101, and does not have 150.

wait_logfile nsd.log "zone example.com. serial 1 is updated to 101" 10
echo ""
echo "> dig example.com"
dig @127.0.0.1 -p $TPKG_PORT example.com SOA > cur
cat cur
if grep "root.example.com. 101 " cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

# send notify 
echo ""
echo "> notify example.com serial 150"
ldns-notify -z example.com -p $TPKG_PORT -s 150 127.0.0.1

# wait for retries
echo ""
sleep 20

count=`grep "request incremental zone transfer (IXFR) for example.com." nsd.log | wc -l`
echo "Number of transfers: $count"
if test $count -gt 10; then
	echo "Number larger than 10, not OK"
	#exit 1
else
	echo "OK"
fi

# test that server is up
echo ""
echo "> dig example.com"
dig @127.0.0.1 -p $TPKG_PORT example.com SOA > cur
cat cur
if grep "root.example.com. 101 " cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo "OK"
exit 0
