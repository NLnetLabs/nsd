# #-- print_apl.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh
PRE="../.."

wait_logfile nsd.log "zone example.com. bad transfer 3" 3
#wait_logfile nsd.log "zone example.com. serial 0 is updated to 3" 10
if grep "zone example.com. bad transfer 3" nsd.log; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

# not reached, attempt to print the output
# It is not reached because the malformed APL is rejected, that rejects
# the zone transfer.

echo "OK"
exit 0
