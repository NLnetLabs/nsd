# #-- axfr_oversize_rr.pre--#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test
. ../common.sh

# start NSD
get_random_port 1
TPKG_PORT=$RND_PORT

PRE="../.."
TPKG_NSD="$PRE/nsd"

# share the vars
echo "export TPKG_PORT=$TPKG_PORT" >> .tpkg.var.test

# put an oversized RR in the zone.
# That does not fit in a 65535 message.
echo "txt IN TXT (" >> axfr_oversize_rr.zone
for((i=0; i<255; i++)); do
	# 255 long string, with length is 256 bytes.
	echo '"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"' >> axfr_oversize_rr.zone
done
# and a 254 long string, with length is 255 bytes.
# for 255*256 + 255 = 65535 bytes rdata for the TXT record
echo '"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"' >> axfr_oversize_rr.zone
echo ")" >> axfr_oversize_rr.zone

$TPKG_NSD -c axfr_oversize_rr.conf -u "" -p $TPKG_PORT
#$TPKG_NSD -c axfr_oversize_rr.conf -u "" -p $TPKG_PORT -d -l /dev/stderr -F -1 -L 2 2>&1 | tee nsd.log &
wait_nsd_up nsd.log
