# #-- ixfr_large_soa.test --#
# source the master var file when it's there
[ -f ../.tpkg.var.master ] && source ../.tpkg.var.master
# use .tpkg.var.test for in test variable passing
[ -f .tpkg.var.test ] && source .tpkg.var.test

. ../common.sh
PRE="../.."

echo ""
echo "> dig example.com"
dig @127.0.0.1 -p $TPKG_PORT example.com SOA > cur
cat cur
if grep "root.example.com" cur; then
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo ""
echo "> IXFR query with large SOA"

# header, ID, flags, qdcount=1, ancount=0, nscount=1, arcount=0
echo "1144 0000 0001 0000 0001 0000" > packet
# qname
echo "07 6578616d706c65 03 636f6d 00" >> packet
# qtype qclass
echo "00fb 0001" >> packet
# authority section SOA record
# owner
echo "00" >> packet
# type class ttl
echo "0006 0001 00000000" >> packet
# rdlength
echo "4e20" >> packet
# 20000 zeroes
for((i=0; i<200; i++)); do
	# 100 zero bytes
	echo "00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000 00000000000000000000" >> packet
done

drill -t -f packet @127.0.0.1 -p $TPKG_PORT 2>&1 | tee result
if grep "FORMERR" result; then
	# the malformed SOA record is rejected with FORMERR.
	echo "OK"
else
	echo "not OK"
	exit 1
fi

echo "OK"
exit 0
